[push]
  default = simple
[user]
  name = Lacy Morrow
  email = me@lacymorrow.com
[color]
  ui = auto
[color "branch"]
  current = yellow reverse
  local = yellow
  remote = green
[color "diff"]
  meta = yellow bold
  frag = magenta bold
  old = red bold
  new = green bold
[color "status"]
  added = yellow
  changed = green
  untracked = cyan
[color]
  ui = true
[color "diff"]
  whitespace = red reverse
[core]
  excludesfile = ~/.gitignore
  whitespace=fix,-indent-with-non-tab,trailing-space,cr-at-eol
[alias]
  st = status
  ch = checkout
  ck = checkout
  chk = checkout
  ci = commit
  cp = cherry-pick
  com = checkout master
  br = branch
  co = checkout
  df = diff
  dif = diff
  dc = diff --cached
  mg = merge
  lg = log -p
  lol = log --graph --decorate --pretty=oneline --abbrev-commit
  lola = log --graph --decorate --pretty=oneline --abbrev-commit --all
  ls = ls-files
  hist = log --pretty=format:\"%h %ad | %s%d [%an]\" --graph --date=short
  type = cat-file -t
  dump = cat-file -p
  up = pull --rebase
  pul = pull
  pulll = pull
  pu = push --set-upstream origin `git symbolic-ref --short HEAD`
  pushup = push --set-upstream origin `git symbolic-ref --short HEAD`
  fuck = reset HEAD --hard

  # Show files ignored by git:
  ign = ls-files -o -i --exclude-standard
